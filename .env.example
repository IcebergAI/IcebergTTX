# Postgres only. The app uses an async driver (asyncpg); a plain
# postgresql:// URL is automatically upgraded to postgresql+asyncpg://.
DATABASE_URL=postgresql+asyncpg://iceberg_ttx:iceberg_ttx@localhost:5432/iceberg_ttx

# REQUIRED in production. Generate a strong value:
#   python -c "import secrets; print(secrets.token_hex(32))"
# The app refuses to start (outside DEV_MODE) if this is unset, equal to the
# insecure default, or shorter than 32 characters.
SECRET_KEY=change-me-to-a-long-random-string

ACCESS_TOKEN_EXPIRE_MINUTES=480
ANTHROPIC_API_KEY=

# Local development over plain HTTP. When true, relaxes the SECRET_KEY startup
# check, serves the auth cookie WITHOUT the Secure flag, and suppresses the
# Strict-Transport-Security response header (#77). NEVER set in production.
DEV_MODE=true

# --- Security hardening (optional overrides) ---
# Force/relax the Secure cookie flag explicitly (defaults to "not DEV_MODE").
# COOKIE_SECURE=true
# Extra origins allowed to drive cookie-authenticated state-changing requests
# (comma-separated host[:port], in addition to same-origin). Usually unneeded.
# TRUSTED_ORIGINS=app.example.com
# Login brute-force protection (#11).
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_SECONDS=300
# Trusted-proxy allowlist for X-Forwarded-For (#36). uvicorn only rewrites the
# client IP from XFF when the peer matches this (default 127.0.0.1). The Docker/
# k8s images default it to "*" because the app sits behind nginx only; leave it
# UNSET for local `uvicorn --reload` (no proxy) so XFF is never trusted.
# FORWARDED_ALLOW_IPS=*
# Persist audit events to the AuditEvent table in addition to the audit log (#23).
# AUDIT_PERSIST=true

# --- SIEM forwarding (#24) ---
# Ship audit events off-host to a SIEM. The app is the forwarder (no sidecar);
# these values *seed* the admin-editable config on first startup — change routing
# live at /admin/audit thereafter. stdout is always on (the audit log handler);
# file/syslog/http are additive forwarders. A failing/unreachable SIEM never
# blocks a request.
# SIEM_ENABLED=false
# SIEM_METHODS=stdout            # comma list: stdout,file,syslog,http
# SIEM_MIN_SEVERITY=info         # info | warning | critical
# SIEM_FILE_PATH=/var/log/iceberg-ttx/audit.log
# SIEM_SYSLOG_HOST=localhost
# SIEM_SYSLOG_PORT=514
# SIEM_SYSLOG_PROTOCOL=UDP       # UDP | TCP (point TCP at a TLS syslog collector)
# SIEM_HTTP_ENDPOINT=https://siem.example.com/services/collector
# SIEM_HTTP_VERIFY_TLS=true
# SECRET — bearer token for the HTTP sink. Env-only: never stored in the DB,
# never returned by the API, never logged.
# SIEM_HTTP_TOKEN=

# --- Postgres (used by docker-compose) ---
# REQUIRED for `docker compose up`: compose reads this file to set the postgres
# container's password and to build the app's DATABASE_URL. The app itself ignores
# it (it connects via DATABASE_URL above); it lives here because compose and the
# app share this .env. Not used by local `uvicorn --reload` or the test suite.
POSTGRES_PASSWORD=changeme
# A plain postgresql:// URL is accepted and upgraded to asyncpg automatically.
# DATABASE_URL=postgresql://iceberg_ttx:changeme@db:5432/iceberg_ttx
