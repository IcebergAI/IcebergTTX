# IcebergTTX reverse proxy (Docker Compose) — Caddy with automatic HTTPS.
#
# SITE_ADDRESS selects the TLS behaviour:
#   localhost (default) → Caddy's internal self-signed CA — for local `docker compose up`
#   your.domain.com     → automatic Let's Encrypt cert (needs public :80 + :443 + DNS)
#   :80  /  http://…    → plain HTTP only (put a TLS proxy in front; not recommended)
{$SITE_ADDRESS:localhost} {
	# Match the app's 25 MB attachment limit with headroom. The app enforces its
	# own cap; this just rejects absurd bodies at the edge.
	request_body {
		max_size 30MB
	}

	# Serve compiled static assets directly from the shared volume, bypassing the
	# app. Security headers (CSP, HSTS, X-Frame-Options, …) are emitted by the
	# app's SecurityHeadersMiddleware — the single source of truth — so Caddy adds
	# only nosniff (belt-and-braces) plus long-lived immutable caching here.
	handle_path /static/* {
		root * /app/static
		file_server
		header Cache-Control "public, immutable"
		header X-Content-Type-Options nosniff
	}

	# Everything else → the app. Caddy proxies WebSocket upgrades transparently
	# (streamed, no idle-kill — no long read-timeout to configure) and sets
	# X-Forwarded-For / -Proto / -Host automatically for the app's client-IP and
	# audit logic (#36).
	reverse_proxy app:8000

	# Access log to stderr with the `token` query param stripped. Browser sockets
	# authenticate from the httpOnly cookie so the JWT is never in the URL (#68);
	# this scrubs the token from the non-browser ?token= fallback as defence in
	# depth so a bearer JWT can never land in a log line.
	log {
		output stderr
		format filter {
			request>uri query {
				delete token
			}
		}
	}
}
